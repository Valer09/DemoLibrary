

type Query {
    booksByAuthor(isni: String!): [BookNto!]!
}

type BookNto {
    title: String
    isbn: String
    author: String
    authorIsni: String
    publishedDate: String
    state: String
    authorNto: AuthorNto
    }

type AuthorNto {
    isni : String,
    name : String
    lastName : String
    birth : String
    }
