<configuration>
    <!-- Console Appender per visualizzare i log nella console -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>LOG - [Correlation ID: %X{X-Correlation-ID}] %d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="staging">
        <root level="warn">
            <appender-ref ref="STDOUT" />
        </root>
        <logger name="org.springframework" level="warn"/>
    </springProfile>
    <springProfile name="debug">
        <root level="debug">
            <appender-ref ref="STDOUT" />
        </root>
        <logger name="org.springframework" level="debug"/>
    </springProfile>
    <springProfile name="dev">
        <root level="info">
            <appender-ref ref="STDOUT" />
        </root>
        <logger name="org.springframework" level="info"/>
    </springProfile>
</configuration>
